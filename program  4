arr = [1, 2, 3, 4, 5]  # input 
target = 5

result = []

for i in range(len(arr)):
    for j in range(i + 1, len(arr)):
        if arr[i] + arr[j] == target:

            pair = [min(arr[i], arr[j]), max(arr[i], arr[j])]

            if pair not in result:
                result.append(pair)

print(result)
